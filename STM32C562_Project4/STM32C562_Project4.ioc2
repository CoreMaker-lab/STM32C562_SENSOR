      }
    ],
    "overridePackMappingRules": [
      {
        "selectors": [
          {
            "packVendor": "ARM"
          },
          {
            "packName": "*CMSIS*"
          }
        ],
        "path": "arch/{{packName}}"
      },
      {
        "selectors": [
